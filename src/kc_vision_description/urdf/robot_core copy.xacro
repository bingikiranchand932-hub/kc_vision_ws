<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot">

<xacro:include filename="$(find kc_vision_description)/urdf/project_visionkc.gazebo" />


  <material name="silver">
    <color rgba="0.700 0.700 0.700 1.000"/>
  </material>

  <material name="aluminium">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="rubber_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="black_pure">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="yellow">
    <color rgba="0.8 0.8 0.0 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="sky_blue">
    <color rgba="0.53 0.81 0.92 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.59 0.29 0.0 1.0"/>
  </material>

  <material name="pink">
    <color rgba="1.0 0.75 0.79 1.0"/>
  </material>

  <material name="ash">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
 
  

<!-- BASE_FOOTPRINT -->
<link name="base_footprint"/>  

<joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
</joint>



<link name="base_link">
